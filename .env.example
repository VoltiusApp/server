# ============================================================================
# Voltius server configuration
# ----------------------------------------------------------------------------
# Variables marked [required] must be set or the server will not start.
# Everything else is opt-in — see the section comments for when to set it.
# ============================================================================


# --- Required ---------------------------------------------------------------

DATABASE_URL=postgres://user:pass@localhost/voltius   # [required] Postgres connection string
JWT_SECRET=change-me-to-32-bytes-of-random-data       # [required] >=32 random bytes (e.g. `openssl rand -hex 32`)
PORT=8080                                             # [required] HTTP listen port


# --- Self-hosting mode ------------------------------------------------------
# Set when you are running your own instance and not selling subscriptions.
# When enabled: all tier-gated features are unlocked, no caps are enforced
# (unless re-introduced below), the billing endpoints return 503, and new
# accounts skip the 14-day trial.

# SELF_HOSTED=true

# Optional caps — only consulted when SELF_HOSTED=true. Unset = unlimited.
# MAX_CONCURRENT_TERMINAL_SESSIONS_PER_USER=10
# MAX_TERMINAL_GUESTS_PER_SESSION=20


# --- Admin dashboard --------------------------------------------------------
# Required only if you deploy the separate admin dashboard. Skip otherwise.

# ADMIN_SECRET=change-me-to-32-bytes-of-random-data


# --- Email (optional, recommended) ------------------------------------------
# Without this, email verification and team invitations silently no-op.
# Accounts can still be created; users just don't receive mail.

# RESEND_API_KEY=re_...                               # https://resend.com/api-keys


# --- CORS + reverse proxy (optional) ----------------------------------------

# CORS_ORIGINS=https://voltius.app,tauri://localhost  # comma-separated; omit = allow all (not for prod)
# TRUSTED_PROXY_IP=127.0.0.1                          # only this peer's X-Forwarded-For is trusted; leave unset in dev


# --- Rate limit tunables (optional) -----------------------------------------
# Defaults are sensible. Override only if you know why.

# SYNC_RATE_LIMIT=60       # sync reads/writes per hour per IP (default: 60)
# REGISTER_RATE_LIMIT=20   # new account registrations per day per IP (default: 20)
# INVITE_RATE_LIMIT=20     # team invitations (email sends) per hour per IP (default: 20)


# --- Billing (maintainer use only) ------------------------------------------
# These variables configure the Lemon Squeezy integration used by the official
# hosted Voltius service. They are not intended for self-hosters and are
# ignored whenever SELF_HOSTED=true is set above (billing endpoints return 503
# regardless).

# LEMONSQUEEZY_SIGNING_SECRET=whsec_...
# LEMONSQUEEZY_STORE_ID=000000        # numeric store ID from LS dashboard → Settings → General
# LEMONSQUEEZY_API_KEY=your-api-key   # LS dashboard → Settings → API
# LS_VARIANT_PRO_MONTHLY=000000
# LS_VARIANT_PRO_YEARLY=000001
# LS_VARIANT_TEAMS_MONTHLY=000002
# LS_VARIANT_TEAMS_YEARLY=000003
# LS_TEST_MODE=false                  # set to true to create test-mode checkouts

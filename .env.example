DATABASE_URL=postgres://user:pass@localhost/voltius
JWT_SECRET=change-me-to-32-bytes-of-random-data
PORT=8080

# LemonSqueezy — set once products are created in the LS dashboard
LEMONSQUEEZY_SIGNING_SECRET=whsec_...
LEMONSQUEEZY_STORE_ID=000000        # numeric store ID from LS dashboard → Settings → General
LEMONSQUEEZY_API_KEY=your-api-key   # LS dashboard → Settings → API
LS_VARIANT_PRO_MONTHLY=000000
LS_VARIANT_PRO_YEARLY=000001
LS_VARIANT_TEAMS_MONTHLY=000002
LS_VARIANT_TEAMS_YEARLY=000003
LS_TEST_MODE=false                  # set to true to create test-mode checkouts

# CORS — comma-separated list of allowed origins (omit to allow all, not recommended for prod)
CORS_ORIGINS=https://voltius.app,tauri://localhost

# Rate limiting — IP of your reverse proxy (nginx/caddy); only that peer's X-Forwarded-For is trusted
# Leave unset in local dev (rate limiter will use the real peer address directly)
TRUSTED_PROXY_IP=127.0.0.1

# Rate limit tunables (requests per window, per IP)
# SYNC_RATE_LIMIT=60       # sync reads/writes per hour (default: 60)
# REGISTER_RATE_LIMIT=20   # new account registrations per day per IP (default: 20)
# INVITE_RATE_LIMIT=20     # team invitations (email sends) per hour (default: 20)
